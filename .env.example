# ============================================
# WhatsApp Auto-Coder — Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- OpenRouter (for OWL model in n8n Agent node) ---
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Claude Code (headless execution) ---
# Option A: Anthropic API key (recommended for headless)
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Option B: If using OpenRouter for Claude too, set:
# OPENROUTER_MODEL=anthropic/claude-sonnet-4-6

# --- GitHub CLI ---
# Your GitHub Personal Access Token (repo, pull_request:write scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=preetbiswas12

# --- Auto-merge behavior ---
# Set to "false" to disable auto-merge (PR will be created but not merged)
AUTO_MERGE_ENABLED=true

# --- WhatsApp Business API (Twilio) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# --- WhatsApp Business API (Meta) ---
META_APP_ID=xxxxxxxxxxxxxxxx
META_APP_SECRET=xxxxxxxxxxxxxxxx
META_ACCESS_TOKEN=xxxxxxxxxxxxxxxx
META_PHONE_NUMBER_ID=xxxxxxxxxxxxxxxx

# --- n8n Configuration ---
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# N8N_API_KEY= (if using n8n cloud or secured instance)

# --- Workspace ---
# Where Claude Code builds projects
WORKSPACE_ROOT=C:\tmp\auto-coder

# --- Rate Limiting ---
MAX_EXECUTIONS_PER_MINUTE=5
MAX_CONCURRENT_JOBS=2
